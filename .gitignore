# Non-website folders (sit alongside the repo but aren't part of the site).
# Leading slash anchors the pattern to the repo root so we don't accidentally
# ignore e.g. functions/api/leads/ (case-insensitive filesystems match "Leads").
/Business Cards/
/Buyers List/
/CRM/
/LOgo Package/
/Leads/
/Legal Registration/
/SOP/

# Legacy local scratch folder — contents of the site now live at the repo root.
# Safe to delete when no processes are holding it open.
/Website/

# The internal business app (separate repo: transitionfl-app) — lives here
# on disk for convenience but has its own git repo under /app/.git/.
/app/
