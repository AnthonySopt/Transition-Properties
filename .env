# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Admin Dashboard Password ──────────────────────────────────────────────────
# Log in at http://localhost:3000/admin with username "admin" and this password
ADMIN_PASSWORD=change-me-before-deploying

# ── Email Notifications (optional) ───────────────────────────────────────────
# When a lead submits a form, an email is sent to NOTIFY_EMAIL.
# If SMTP_HOST is blank, email is disabled (leads still save to the database).

# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your-app-password   ← generate at myaccount.google.com/apppasswords

# SendGrid example:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=apikey
#   SMTP_PASS=SG.xxxxxxxxxxxx

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Email address that receives lead notifications
NOTIFY_EMAIL=leads@transitionfl.com
